{
  "name": "web-project-template",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --cwd packages/api dev",
    "dev:web": "bun --cwd packages/web dev",
    "db:generate": "bun --cwd packages/api db:generate",
    "db:migrate": "bun --cwd packages/api db:migrate",
    "test": "bun test",
    "test:api": "bun --cwd packages/api test",
    "test:web": "bun --cwd packages/web test",
    "test:docker": "docker compose exec api bun test"
  }
}
