---
import '../styles/global.css'
import Counter from '../components/Counter.svelte'
import { INTERNAL_API_URL } from 'astro:env/server'

let apiStatus = 'unreachable'
try {
  const res = await fetch(INTERNAL_API_URL)
  if (res.ok) apiStatus = 'ok'
} catch {
  apiStatus = 'unreachable'
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>web_project_template</title>
  </head>
  <body class="min-h-screen bg-gray-50 flex flex-col items-center justify-center gap-4">
    <h1 class="text-2xl font-bold">web_project_template</h1>
    <p>API status: {apiStatus}</p>
    <Counter client:load />
  </body>
</html>
